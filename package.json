{
  "name": "tom-quest",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.3",
  "scripts": {
    "dev": "next dev",
    "dev:all": "concurrently \"pnpm dev\" \"npx convex dev\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "jarvis:device": "node scripts/generate-jarvis-device-identity.mjs",
    "secrets:init": "node scripts/sync-secrets.mjs --init",
    "secrets:sync": "node scripts/sync-secrets.mjs",
    "secrets:prune": "node scripts/sync-secrets.mjs --prune",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:pages": "vitest run app/components/page-routes.test.ts && playwright test e2e/page-visibility.spec.ts",
    "test:auth": "playwright test e2e/auth-flow.spec.ts",
    "test:jarvis": "vitest run app/jarvis/components/__tests__ app/api/jarvis/config/route.test.ts",
    "test:turing": "vitest run convex/convex.test.ts",
    "test:observability": "vitest run app/lib/__tests__/debug.test.ts",
    "check:auth-boundary": "node scripts/check-auth-boundary.mjs",
    "check:heavy-libs": "node scripts/check-heavy-libs.mjs",
    "check:secrets": "gitleaks detect --source . --no-banner --redact",
    "check:guardrails": "node scripts/check-auth-boundary.mjs && node scripts/check-heavy-libs.mjs"
  },
  "dependencies": {
    "@convex-dev/auth": "^0.0.92",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@sentry/nextjs": "^10",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "convex": "^1.37.0",
    "next": "16.1.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "three": "^0.184.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.0",
    "concurrently": "^9.2.1",
    "convex-test": "^0.0.51",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "jsdom": "^24.1.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
