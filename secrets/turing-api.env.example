# Template for secrets/turing-api.env. Real file is gitignored.
# Holds the runtime env for the Turing API (FastAPI service in turing-api/).
#
# Unlike next.env / convex.env, this file is not pushed by `pnpm secrets:sync`
# because the Turing cluster is not a managed platform we can talk to over an
# API. Edit values here, then scp the file to the cluster:
#
#   scp secrets/turing-api.env <user>@<turing-host>:~/tom.quest/turing-api/.env

# Shared API key. Must match TURING_API_KEY in next.env and convex.env.
TURING_API_KEY=

# Optional: override the default port (8000).
# API_PORT=
