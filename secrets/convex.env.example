# Template for secrets/convex.env. Real file is gitignored.
# Run `pnpm secrets:init` to populate from your current Convex prod env.

# Convex Auth signing keys.
JWT_PRIVATE_KEY=
JWKS=

# The public site URL Convex Auth uses for the "site URL" identity claim.
SITE_URL=

# Tom-account promotion gate (used by api.users.setTomByUsername).
TOM_SETUP_SECRET=

# Turing API — used by internal.serverHealth.pollTuring cron action.
# Same values as TURING_API_URL / TURING_API_KEY in next.env.
TURING_API_URL=
TURING_API_KEY=
