# Template for secrets/next.env. Real file is gitignored.
# Run `pnpm secrets:init` to populate from your current Vercel prod env.

# Convex platform — wire Next.js to the Convex deployment.
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=
CONVEX_DEPLOY_KEY=

# Sentry source maps (build-time).
SENTRY_AUTH_TOKEN=

# Turing (named cloudflared tunnel + API key).
TURING_API_URL=
TURING_API_KEY=

# Jarvis socket (and optional shared device identity).
OPENCLAW_GATEWAY_URL=
JARVIS_GATEWAY_PASSWORD=
# JARVIS_DEVICE_ID=
# JARVIS_DEVICE_PUBLIC_KEY=
# JARVIS_DEVICE_PRIVATE_KEY=

# Canvas page LLM credentials (server-side only).
# CODEX_AUTH_JSON=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
